# --- LLM API Settings ---
GROQ_API_KEY=your_groq_api_key
AI_MODEL=llama-3.3-70b-versatile

# --- YouTube Upload Settings ---
CLIENT_SECRETS_FILE=client_secrets.json

# --- Smart Scheduling (2025-2026 Strategy) ---
POSTING_GAP_HOURS=6
MAX_POSTS_PER_DAY=3

# --- Instagram Auto-Sync ---
# USER: Your own username (used to load the session file)
# PROFILE: The username of the account you want to download Reels from
INSTAGRAM_USER=your_instagram_username
INSTAGRAM_PROFILE=target_profile_to_sync
